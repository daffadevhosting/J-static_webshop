---
layout: null
---
[
  {% for product in site.data.data_product %}
    {
      "title"    : "{{ product.title | escape }}",
      "url"      : "{{ product.url | relative_url }}",
      "image"    : "{{ product.img | relative_url }}",
      "price"    : "{{ product.harga }}"
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]